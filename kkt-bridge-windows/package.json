{
  "name": "kkt-bridge-windows",
  "version": "1.0.0",
  "description": "АТОЛ ККТ Bridge для Windows — соединяет физическую кассу АТОЛ с облачным сервером",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win --publish never",
    "build:dir": "electron-builder --win --dir"
  },
  "build": {
    "appId": "ru.hookahpos.kkt-bridge",
    "productName": "HookahPOS KKT Bridge",
    "copyright": "Copyright © 2025 HookahPOS",
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "HookahPOS KKT Bridge",
      "runAfterFinish": true
    },
    "files": ["src/**/*", "assets/**/*", "node_modules/**/*"],
    "extraResources": [],
    "asar": true
  },
  "dependencies": {
    "axios": "^1.6.0",
    "socket.io-client": "^4.7.0",
    "electron-store": "^8.2.0",
    "auto-launch": "^5.0.6"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  }
}
